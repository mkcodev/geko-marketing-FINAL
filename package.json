{
  "name": "geko-marketing",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prepare": "husky",
    "test": "/bin/bash -c 'FILES=$(find __tests__ -name \"*.test.ts\" -o -name \"*.test.tsx\" | sort | tr \"\\n\" \" \") && pnpm exec vitest run --pool vmThreads $FILES'",
    "test:watch": "pnpm exec vitest",
    "test:ui": "pnpm exec vitest --ui",
    "test:coverage": "/bin/bash -c 'FILES=$(find __tests__ -name \"*.test.ts\" -o -name \"*.test.tsx\" | sort | tr \"\\n\" \" \") && pnpm exec vitest run --pool vmThreads --coverage $FILES'"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "bash -c 'pnpm tsc --noEmit'"
    ],
    "*.{ts,tsx,css,json,md}": []
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@fontsource-variable/bricolage-grotesque": "^5.2.10",
    "@fontsource-variable/geist": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@keystatic/core": "^0.5.50",
    "@keystatic/next": "^5.0.4",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@remotion/player": "^4.0.448",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fuse.js": "^7.3.0",
    "gsap": "^3.14.2",
    "lenis": "^1.3.21",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-calendly": "^4.4.0",
    "react-dom": "19.2.4",
    "react-google-recaptcha-v3": "^1.11.0",
    "react-hook-form": "^7.72.1",
    "react-loading-skeleton": "^3.5.0",
    "remotion": "^4.0.448",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "shadcn": "^4.2.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
